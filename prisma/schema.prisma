generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  email        String   @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Subscription {
  id                      String   @id
  userId                  String
  providerName            String
  category                String
  status                  String
  billingCadence          String
  intervalDays            Int?
  priceAmount             Float
  currency                String
  startDate               String?
  renewalDate             String?
  trialStartDate          String?
  trialEndDate            String?
  cancelByDate            String?
  postTrialPriceAmount    Float?
  accountEmailForProvider String?
  loginUrl                String?
  billingUrl              String?
  cancelUrl               String?
  supportUrl              String?
  paymentMethodLabel      String?
  notes                   String?
  lastUsageDate           String?
  isShared                Boolean  @default(false)
  splitType               String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, renewalDate])
}

model Household {
  id          String   @id
  ownerUserId String   @unique
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HouseholdMember {
  id          String   @id
  householdId String
  name        String
  email       String?
  role        String
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([householdId])
}

model SubscriptionShare {
  id             String   @id
  subscriptionId String
  memberId       String
  fixedAmount    Float?
  percentage     Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([subscriptionId, memberId])
  @@index([subscriptionId])
  @@index([memberId])
}

model BudgetSettings {
  id            String   @id
  userId        String   @unique
  monthlyTarget Float?
  currency      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CategoryBudget {
  id            String   @id
  userId        String
  category      String
  monthlyTarget Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, category])
  @@index([userId])
}

model DetectedCandidate {
  id                    String   @id
  userId                String
  merchantLabel         String
  normalizedMerchant    String
  billingCadence        String
  intervalDays          Int?
  lastAmount            Float
  averageAmount         Float
  occurrenceCount       Int
  firstChargeDate       String
  lastChargeDate        String
  nextEstimatedCharge   String?
  confidence            Float
  categoryGuess         String
  evidenceJson          String
  status                String
  matchedSubscriptionId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([userId, normalizedMerchant])
  @@index([userId, status])
}

model Notification {
  id             String    @id
  userId         String
  subscriptionId String
  type           String
  channel        String
  status         String
  scheduledFor   DateTime
  sentAt         DateTime?
  readAt         DateTime?
  dedupeKey      String    @unique
  payloadTitle   String
  payloadBody    String
  payloadUrl     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId, status, scheduledFor])
  @@index([subscriptionId])
}
