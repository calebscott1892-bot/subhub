DATABASE_URL="file:./dev.db"

# Optional: lets external schedulers POST /api/jobs/send-notifications with an
# x-job-secret header to deliver due reminders for all users.
JOB_SECRET=""

# Optional: real email delivery via Resend. Without a key, emails go to the
# server log. EMAIL_FROM must be a sender verified in your Resend account.
RESEND_API_KEY=""
EMAIL_FROM=""

# Production only: protects GET /api/jobs/send-notifications for Vercel Cron
# (Vercel sends it as an Authorization: Bearer header automatically).
CRON_SECRET=""
